                        <div style="position: absolute; top: 20px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.7); color: #fff; padding: 18px 32px; border-radius: 14px; font-size: 1.1rem; font-weight: 600; z-index: 10; box-shadow: 0 4px 24px rgba(0,210,255,0.12);">
