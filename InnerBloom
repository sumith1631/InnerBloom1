    <script>
                                                // Dynamically show all nearby medical facilities and pharmacies within 20km
                                                function showNearbyMedicalFacilities() {
                                                    if (navigator.geolocation) {
                                                        navigator.geolocation.getCurrentPosition(function(position) {
                                                            const userLat = position.coords.latitude;
                                                            const userLng = position.coords.longitude;
                                                            // Google Maps Places search for hospitals and pharmacies within 20km
                                                            const hospitalUrl = `https://www.google.com/maps/search/hospital/@${userLat},${userLng},12z`;
                                                            const pharmacyUrl = `https://www.google.com/maps/search/pharmacy/@${userLat},${userLng},12z`;
                                                            // Render cards
                                                            document.getElementById('nearby-medical-list').innerHTML = `
                                                                <div class='glass-card' style='min-width:340px;max-width:480px;height:180px;display:flex;gap:30px;align-items:center;font-size:1.2rem;'>
                                                                    <i class='fas fa-hospital-user' style='font-size:4rem;color:var(--accent);'></i>
                                                                    <div>
                                                                        <h2 style='margin:0;'>Nearest Hospitals</h2>
                                                                        <p style='opacity:0.7;'>Within 20km radius</p>
                                                                        <a href='${hospitalUrl}' target='_blank'>
                                                                            <button style='background:var(--accent);border:none;padding:12px 24px;border-radius:8px;font-weight:bold;cursor:pointer;'>View All Hospitals</button>
                                                                        </a>
                                                                    </div>
                                                                </div>
                                                                <div class='glass-card' style='min-width:340px;max-width:480px;height:180px;display:flex;gap:30px;align-items:center;font-size:1.2rem;'>
                                                                    <i class='fas fa-prescription-bottle-alt' style='font-size:4rem;color:#00d2ff;'></i>
                                                                    <div>
                                                                        <h2 style='margin:0;'>Nearest Pharmacies</h2>
                                                                        <p style='opacity:0.7;'>Within 20km radius</p>
                                                                        <a href='${pharmacyUrl}' target='_blank'>
                                                                            <button style='background:#00d2ff;border:none;padding:12px 24px;border-radius:8px;font-weight:bold;cursor:pointer;'>View All Pharmacies</button>
                                                                        </a>
                                                                    </div>
                                                                </div>
                                                            `;
                                                        }, function(error) {
                                                            document.getElementById('nearby-medical-list').innerHTML = '<div style="color:#fff;font-size:1.2rem;">Unable to access your location. Please allow location access or check your browser settings.</div>';
                                                        });
                                                    } else {
                                                        document.getElementById('nearby-medical-list').innerHTML = '<div style="color:#fff;font-size:1.2rem;">Geolocation is not supported by your browser.</div>';
                                                    }
                                                }
                                                // Call on page load
                                                window.addEventListener('DOMContentLoaded', showNearbyMedicalFacilities);
                                        function findNearbyPharmacy() {
                                            if (navigator.geolocation) {
                                                navigator.geolocation.getCurrentPosition(function(position) {
                                                    const userLat = position.coords.latitude;
                                                    const userLng = position.coords.longitude;
                                                    const mapsUrl = `https://www.google.com/maps/search/pharmacy/@${userLat},${userLng},16z`;
                                                    window.open(mapsUrl, '_blank');
                                                });
                                            }
                                        }

                                        function shareLocation() {
                                            if (navigator.geolocation) {
                                                navigator.geolocation.getCurrentPosition(function(position) {
                                                    const userLat = position.coords.latitude;
                                                    const userLng = position.coords.longitude;
                                                    const locationText = `My current location: https://maps.google.com/?q=${userLat},${userLng}`;
                                                    if (navigator.share) {
                                                        navigator.share({ title: 'My Location', text: locationText, url: locationText });
                                                    } else {
                                                        prompt('Copy and share your location:', locationText);
                                                    }
                                                });
                                            }
                                        }
                                // Request geolocation immediately and show prompt if denied
                                let userLocation = null;
                                window.addEventListener('DOMContentLoaded', function() {
                                    if (navigator.geolocation) {
                                        navigator.geolocation.getCurrentPosition(function(position) {
                                            userLocation = {
                                                lat: position.coords.latitude,
                                                lng: position.coords.longitude
                                            };
                                        }, function(error) {
                                            alert('Location access is required for map features. Please allow location access in your browser settings.');
                                        });
                                    } else {
                                        alert('Geolocation is not supported by your browser.');
                                    }
                                });
                        function findNearestHospital() {
                            if (navigator.geolocation) {
                                navigator.geolocation.getCurrentPosition(function(position) {
                                    const userLat = position.coords.latitude;
                                    const userLng = position.coords.longitude;
                                    const mapsUrl = `https://www.google.com/maps/search/hospital/@${userLat},${userLng},16z`;
                                    window.open(mapsUrl, '_blank');
                                }, function(error) {
                                    document.getElementById('directions-info').style.display = 'block';
                                    document.getElementById('directions-info').innerHTML = 'Unable to access your location. Please allow location access or check your browser settings.';
                                });
                            } else {
                                document.getElementById('directions-info').style.display = 'block';
                                document.getElementById('directions-info').innerHTML = 'Geolocation is not supported by your browser.';
                            }
                        }
                function showDirections() {
                    if (userLocation) {
                        const annexLat = 13.0215;
                        const annexLng = 77.6141;
                        const mapsUrl = `https://www.google.com/maps/dir/?api=1&origin=${userLocation.lat},${userLocation.lng}&destination=${annexLat},${annexLng}&travelmode=walking`;
                        window.open(mapsUrl, '_blank');
                    } else {
                        alert('Location not found. Please reload and allow location access.');
                    }
                }
        const doctors = [
            { name: "Dr. Ananya Singh", phone: "+91 99880 11223", hosp: "CIT Health Wing", spec: "Cognitive Behavioral Therapy", img: "https://images.unsplash.com/photo-1515378791036-0648a3ef77b2?auto=format&fit=crop&w=150&q=80" },
            { name: "Dr. Rajesh Kumar", phone: "+91 98450 12345", hosp: "Fortis Hospital", spec: "Psychiatrist & Stress Management", img: "https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=150&q=80" },
            { name: "Dr. Meera Nair", phone: "+91 98765 43210", hosp: "Manipal Hospital", spec: "Child & Adolescent Psychologist", img: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=150&q=80" },
            { name: "Dr. Arvind Patel", phone: "+91 99000 56789", hosp: "Apollo Mind Center", spec: "Depression & Mood Disorders", img: "https://images.unsplash.com/photo-1537368910025-700350fe46c7?auto=format&fit=crop&w=150&q=80" },
            { name: "Dr. Priya Sharma", phone: "+91 77665 55443", hosp: "Student Life Hub", spec: "Academic Pressure Coach", img: "https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=150&q=80" },
            { name: "Dr. Suresh Reddy", phone: "+91 99880 11224", hosp: "CIT Health Wing", spec: "Addiction Recovery Specialist", img: "https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=150&q=80" },
            { name: "Dr. Kavita Joshi", phone: "+91 99880 11225", hosp: "Apollo Mind Center", spec: "Family & Relationship Therapy", img: "https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?auto=format&fit=crop&w=150&q=80" }
        ];

        function launchApp() {
            const sid = document.getElementById('studentID').value;
            const email = document.getElementById('parentEmail').value;
            if(!sid || !email) return alert("Security Requirement: Student ID and Parent Email are mandatory.");
            
            document.getElementById('login-screen').style.opacity = '0';
            setTimeout(() => {
                document.getElementById('login-screen').style.display = 'none';
                document.getElementById('app-shell').style.display = 'flex';
                renderDoctors();
            }, 600);
        }

        function nav(id, el) {
            document.querySelectorAll('.window').forEach(w => w.classList.remove('active'));
            document.querySelectorAll('.side-icon').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            el.classList.add('active');

            // Random Background Access based on mood/section
            const bg = document.getElementById('main-bg');
            if(id === 'bot') bg.style.backgroundImage = "url('https://images.unsplash.com/photo-1499209974431-9dac3adaf471?q=80&w=2070&auto=format&fit=crop')";
            if(id === 'doctors') bg.style.backgroundImage = "url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2070&auto=format&fit=crop')";
            if(id === 'dashboard') bg.style.backgroundImage = "url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=2070&auto=format&fit=crop')";
        }

        function handleBot() {
                        function openYouTubeSearch(query) {
                            const videoLink = `https://www.youtube.com/results?search_query=${encodeURIComponent(query)}`;
                            window.open(videoLink, '_blank');
                        }
            const inputField = document.getElementById('u-msg');
            const history = document.getElementById('chat-history');
            let msgText = inputField.value.trim();
            if(!msgText) return;
            history.innerHTML += `<div class="msg user fade-in">${inputField.value}</div>`;
            inputField.value = "";

            setTimeout(() => {
                // Custom response for 'hi'
                if (/^hi$/i.test(msgText) || /^hello$/i.test(msgText) || /^hey$/i.test(msgText)) {
                    history.innerHTML += `<div class="msg bot fade-in">How can I help you about mental health?</div>`;
                    history.scrollTop = history.scrollHeight;
                    return;
                }
                // Use Wikipedia and YouTube for all other questions
                fetch(`https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(msgText)}`)
                    .then(res => res.json())
                    .then(data => {
                        let reply = data.extract ? data.extract : "Sorry, I couldn't find an answer. Please try rephrasing your question.";
                        let videoLink = `https://www.youtube.com/results?search_query=${encodeURIComponent(msgText)}`;
                        reply += `<br><br><b>Watch a video:</b> <a href='${videoLink}' target='_blank' style='color:var(--accent);text-decoration:underline;'>Click here for YouTube solutions</a>`;
                        history.innerHTML += `<div class="msg bot fade-in">${reply}</div>`;
                        history.scrollTop = history.scrollHeight;
                        openYouTubeSearch(msgText);
                    })
                    .catch(() => {
                        let reply = "Sorry, I couldn't find an answer. Please try rephrasing your question.";
                        let videoLink = `https://www.youtube.com/results?search_query=${encodeURIComponent(msgText)}`;
                        reply += `<br><br><b>Watch a video:</b> <a href='${videoLink}' target='_blank' style='color:var(--accent);text-decoration:underline;'>Click here for YouTube solutions</a>`;
                        history.innerHTML += `<div class="msg bot fade-in">${reply}</div>`;
                        history.scrollTop = history.scrollHeight;
                        openYouTubeSearch(msgText);
                    });
            }, 500);
        }

        function renderDoctors() {
            document.getElementById('doctor-grid').innerHTML = doctors.map((d, idx) => `
                <div class="glass-card" style="display:flex; align-items:center; gap:25px;">
                    <img src="${d.img}" style="width:75px; height:75px; border-radius:50%; border:3px solid var(--accent); object-fit:cover;">
                    <div>
                        <h3 style="margin:0">${d.name}</h3>
                        <p style="margin:4px 0; font-size:0.85rem; opacity:0.6;">${d.spec}</p>
                        <p style="margin:8px 0 0; color:var(--accent); font-weight:bold; font-size:0.9rem;"><i class="fas fa-phone"></i> ${d.phone}</p>
                        <p style="margin:2px 0; font-size:0.8rem; opacity:0.5;"><i class="fas fa-building-user"></i> ${d.hosp}</p>
                        <button onclick="startVideoCall(${idx})" style="margin-top:10px;background:var(--accent);color:#000;border:none;padding:10px 22px;border-radius:8px;font-weight:bold;cursor:pointer;">Video Call</button>
                    </div>
                </div>
            `).join('');
        }

        function triggerSOS() {
            const confirmSOS = confirm("ACTIVATE EMERGENCY SOS?\n\nThis will instantly alert CIT Campus Security, the Medical Wing, and send a priority alert to your parents.");
            if(confirmSOS) {
                alert("🚨 SOS ACTIVE 🚨\nAlerts sent. GPS coordinates locked. Stay calm, emergency services are arriving in 3-5 minutes.");
            }
        }

        // Enter key support for chat
                // Video Call Modal and Camera Logic
                // Modal HTML
                if (!document.getElementById('video-call-modal')) {
                    const modal = document.createElement('div');
                    modal.id = 'video-call-modal';
                    modal.style = 'display:none;position:fixed;z-index:3000;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.7);align-items:center;justify-content:center;';
                    modal.innerHTML = `
                        <div style="background:#181f2a;padding:32px 28px;border-radius:18px;box-shadow:0 8px 32px rgba(0,0,0,0.25);display:flex;flex-direction:column;align-items:center;max-width:95vw;max-height:90vh;">
                            <h2 style='color:var(--accent);margin-bottom:18px;'>Video Call with Doctor</h2>
                            <video id="student-video" autoplay playsinline style="width:340px;height:255px;background:#222;border-radius:12px;border:3px solid var(--accent);"></video>
                            <div id="doctor-video-placeholder" style="margin:18px 0 0 0;color:#fff;opacity:0.7;font-size:1.1rem;">Connecting to doctor...</div>
                            <button onclick="closeVideoCall()" style="margin-top:18px;background:var(--danger);color:#fff;border:none;padding:10px 22px;border-radius:8px;font-weight:bold;cursor:pointer;">End Call</button>
                        </div>
                    `;
                    document.body.appendChild(modal);
                }

                window.startVideoCall = function(idx) {
                    const modal = document.getElementById('video-call-modal');
                    modal.style.display = 'flex';
                    // Show doctor name
                    document.getElementById('doctor-video-placeholder').innerHTML = `Connecting to <b>${doctors[idx].name}</b>...<br><span style='font-size:0.95rem;opacity:0.6;'>Doctor will join soon.</span>`;
                    // Show student camera
                    const video = document.getElementById('student-video');
                    if (window.localStream) {
                        video.srcObject = window.localStream;
                        return;
                    }
                    navigator.mediaDevices.getUserMedia({ video: true, audio: false })
                        .then(stream => {
                            window.localStream = stream;
                            video.srcObject = stream;
                        })
                        .catch(() => {
                            document.getElementById('doctor-video-placeholder').innerHTML = 'Unable to access your camera.';
                        });
                }

                window.closeVideoCall = function() {
                    const modal = document.getElementById('video-call-modal');
                    modal.style.display = 'none';
                    // Optionally stop the camera
                    if (window.localStream) {
                        window.localStream.getTracks().forEach(track => track.stop());
                        window.localStream = null;
                    }
                }
        document.getElementById('u-msg').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') handleBot();
        });
    </script>
