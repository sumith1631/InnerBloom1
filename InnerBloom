<!DOCTYPE html>
<html lang="en">
<head>
        <style>
            /* Animations */
            .fade-in {
                animation: fadeIn 1.2s ease;
            }
            .slide-up {
                animation: slideUp 1s ease;
            }
            @keyframes fadeIn {
                from { opacity: 0; }
                to { opacity: 1; }
            }
            @keyframes slideUp {
                from { transform: translateY(40px); opacity: 0; }
                to { transform: translateY(0); opacity: 1; }
            }
            .typing {
                border-right: 2px solid var(--accent);
                white-space: nowrap;
                overflow: hidden;
                animation: typing 2s steps(30, end), blink-caret .75s step-end infinite;
            }
            @keyframes typing {
                from { width: 0 }
                to { width: 100% }
            }
            @keyframes blink-caret {
                from, to { border-color: transparent }
                50% { border-color: var(--accent); }
            }
            /* Wellness Cards */
            .wellness-cards {
                display: flex;
                gap: 20px;
                margin: 40px 0;
                justify-content: center;
            }
            .wellness-card {
                background: rgba(255,255,255,0.07);
                border-radius: 18px;
                padding: 28px 22px;
                box-shadow: 0 8px 32px rgba(0,0,0,0.18);
                font-size: 1.1rem;
                color: #fff;
                transition: transform 0.3s, box-shadow 0.3s;
                cursor: pointer;
            }
            .wellness-card:hover {
                transform: scale(1.05) rotate(-2deg);
                box-shadow: 0 16px 48px rgba(0,210,255,0.18);
            }
        </style>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>InnerBloom</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap');

        :root {
            --glass: rgba(0, 0, 0, 0.75);
            --blur: blur(25px);
            --accent: #00d2ff;
            --danger: #ff4b2b;
            --text-main: #ffffff;
            --sidebar-bg: rgba(10, 10, 15, 0.9);
        }

        body, html {
            margin: 0; padding: 0; min-height: 100vh;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #050505;
            overflow-x: hidden;
            color: var(--text-main);
        }

        /* Dynamic Background */
        .bg-overlay {
            position: absolute; top: 0; left: 0; width: 100vw; height: 100vh;
            background: url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=2070&auto=format&fit=crop') center/cover;
            filter: brightness(0.3) grayscale(0.2);
            z-index: -1;
            transition: background 0.8s ease-in-out;
        }

        /* 1. LOGIN SCREEN */
        #login-screen {
            position: fixed; inset: 0; z-index: 2000;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=2070&auto=format&fit=crop') center/cover;
        }

        .logo-branding {
            position: absolute; top: 30px; left: 30px;
            display: flex; align-items: center; gap: 15px;
            background: rgba(255,255,255,1); padding: 12px 24px; border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .logo-branding img { width: 45px; height: auto; }
        .logo-branding span { color: #000; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.5px; }

        .login-card {
            background: var(--glass); backdrop-filter: var(--blur);
            padding: 50px; border-radius: 35px; width: 420px;
            border: 1px solid rgba(255,255,255,0.1); text-align: center;
            box-shadow: 0 40px 100px rgba(0,0,0,0.6);
        }

        .login-card input {
            width: 100%; padding: 16px; margin: 12px 0; border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); 
            color: white; outline: none; font-size: 1rem; transition: 0.3s;
        }
        .login-card input:focus { border-color: var(--accent); background: rgba(255,255,255,0.1); }

        .login-card button {
            width: 100%; padding: 18px; background: var(--accent); border: none; 
            border-radius: 12px; font-weight: 800; cursor: pointer; margin-top: 20px;
            color: #000; font-size: 1rem; transition: 0.3s;
        }
        .login-card button:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0, 210, 255, 0.4); }

        /* 2. MAIN PC INTERFACE */
        .pc-shell { display: none; height: 100vh; }

        .sidebar {
            width: 100px; background: var(--sidebar-bg); backdrop-filter: blur(15px);
            display: flex; flex-direction: column; align-items: center; padding: 40px 0; gap: 35px;
            border-right: 1px solid rgba(255,255,255,0.05);
        }

        .side-icon {
            text-align: center; cursor: pointer; transition: 0.4s; color: rgba(255,255,255,0.4);
            position: relative; width: 100%;
        }
        .side-icon.active { color: var(--accent); }
        .side-icon.active::after { content: ''; position: absolute; right: 0; top: 10%; height: 80%; width: 4px; background: var(--accent); border-radius: 4px 0 0 4px; }
        .side-icon i { font-size: 1.6rem; }
        .side-icon p { font-size: 9px; margin-top: 8px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }

        .main-stage { flex: 1; padding: 50px; overflow-y: auto; background: rgba(0,0,0,0.1); }

        .window { display: none; max-width: 1100px; margin: 0 auto; animation: fadeInUp 0.6s ease-out; }
        .window.active { display: block; }

        @keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }

        /* Feature Layouts */
        .grid-layout { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 25px; }
        .glass-card {
            background: rgba(255, 255, 255, 0.03); backdrop-filter: var(--blur);
            padding: 30px; border-radius: 24px; border: 1px solid rgba(255,255,255,0.08);
            transition: 0.3s;
        }
        .glass-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.2); }

        .img-block {
            width: 100%; height: 180px; border-radius: 18px; margin-bottom: 20px;
            background-size: cover; background-position: center;
        }

        /* Expert AI Chatbot */
        #chat-box {
            height: 550px; display: flex; flex-direction: column; background: rgba(0,0,0,0.5);
            border-radius: 28px; padding: 25px; border: 1px solid rgba(255,255,255,0.05);
        }
        #chat-history { flex: 1; overflow-y: auto; padding-right: 15px; display: flex; flex-direction: column; }
        .msg { margin: 12px 0; padding: 15px 22px; border-radius: 18px; max-width: 80%; line-height: 1.5; font-size: 0.95rem; }
        .bot { background: rgba(255,255,255,0.1); align-self: flex-start; border-bottom-left-radius: 4px; }
        .user { background: var(--accent); color: #000; align-self: flex-end; border-bottom-right-radius: 4px; font-weight: 600; }

        /* SOS Pulse Button */
        .sos-btn {
            background: var(--danger); color: white; padding: 20px; border-radius: 18px;
            width: 100%; border: none; font-weight: 800; cursor: pointer; letter-spacing: 1px;
            animation: sos-glow 2s infinite;
        }
        @keyframes sos-glow { 0% { box-shadow: 0 0 0 0 rgba(255, 75, 43, 0.6); } 70% { box-shadow: 0 0 0 25px rgba(255, 75, 43, 0); } 100% { box-shadow: 0 0 0 0 rgba(255, 75, 43, 0); } }

    </style>
</head>
